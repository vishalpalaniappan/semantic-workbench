 books name."},"_goToBehaviorIds":["CreateSlotOnBookShelf","AddBookToShelf"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"5b93a325-79a8-4242-a6e7-fdf74dd89797","type":5,"_behavior":{"dal_engine_uid":"fd2d4988-675e-42db-9fe0-81c011b9f409","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"CreateSlotOnBookShelf","_description":"In this behavior, the librarian uses the first letter of the books name to create a slot on the shelf."},"_goToBehaviorIds":["AddBookToShelf"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"1f6e7583-e5c1-42eb-ba96-83507b1bf1cd","type":5,"_behavior":{"dal_engine_uid":"bb4bc249-12ae-4cd2-8b9f-e968fee1213d","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AddBookToShelf","_description":"In this behavior, the librarian adds the book to the shelf in the slot determined by the first letter of the books name."},"_goToBehaviorIds":["GetBookFromBasket"],"_isAtomic":false,"_isDesignFork":false}],"name":"PlaceBookOnShelf","description":""},"AuditLibrary":{"dal_engine_uid":"442e6a9b-9f17-478f-bc59-cea04d08696b","type":4,"nodes":[{"dal_engine_uid":"f1ff2f4a-700c-4efc-b4de-94f49acd8981","type":5,"_behavior":{"dal_engine_uid":"15285457-d9cd-41f7-88b1-e3cb2f055f24","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AcceptChoiceToAuditLibrary","_description":"In this behavior, the librarian accepts the choice to audit the library."},"_goToBehaviorIds":["GenerateAuditReport"],"_isAtomic":true,"_isDesignFork":false},{"dal_engine_uid":"fb7077fc-981a-439a-b3ad-a3dafbded661","type":5,"_behavior":{"dal_engine_uid":"e74db9cc-aa17-40e1-957c-c8ca6bbca42a","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"GenerateAuditReport","_description":"In this behavior, the librarian generates the audit report."},"_goToBehaviorIds":["HandAuditToUser"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"021bc3df-9945-437d-9bb6-4a526e21d9f6","type":5,"_behavior":{"dal_engine_uid":"dd55c7e3-64cf-4e0d-93f6-9c80a136bf0c","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"HandAuditToUser","_description":"In this behavior, the librarian hands the audit to the user."},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false}],"name":"AuditLibrary","description":""}},"_activeGraph":{"dal_engine_uid":"050136de-9c83-4ff8-b130-2e487d342882","type":4,"nodes":[{"dal_engine_uid":"f98487c9-e243-4a0b-ae55-58690d1394b9","type":5,"_behavior":{"dal_engine_uid":"a6982745-b99e-4bca-9f3f-6ecc5f9c69d7","_type":1,"_participants":[{"dal_engine_uid":"5eff0b21-8943-4c36-a5e0-a3989e8515ff","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Choice","_description":"This participant represents the choice made by the user to add a book to the basket."},{"dal_engine_uid":"d301d118-afa9-4d8a-be00-e8e298dd8f23","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"User","_description":"In this design, the user represents the environments presence in the library."},{"dal_engine_uid":"afd4c645-25d0-4a4f-a886-bb0c68e9779a","_type":3,"_invariants":[],"_abstractionId":null,"_invariantViolated":false,"_name":"Librarian","_description":"The librarian accepts the choice from the user."}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AcceptChoiceToAddBookToBasket","_description":"This atomic behavior starts the design flow by accepting the choice to add a book to the basket."},"_goToBehaviorIds":["AcceptBookFromUser"],"_isAtomic":true,"_isDesignFork":false},{"dal_engine_uid":"fdb91763-0344-41c5-8ae0-e143d435907c","type":5,"_behavior":{"dal_engine_uid":"f08b6523-f7f0-4845-806e-37cafce916f5","_type":1,"_participants":[{"dal_engine_uid":"9ad1ea7f-c8ab-4817-b379-22da1dc155b6","_type":3,"_invariants":[{"dal_engine_uid":"bd1827dc-9639-455e-a420-ba766638a024","type":2,"invariantViolated":null,"invariantType":{"type":"min_length","label":"Minimum Length","properties":{"keys":{"label":"Key(s) of value in object","type":"Array","required":true,"value":["name"]},"minLength":{"label":"Minimum Length","type":"string","required":true,"value":"1"}},"invariantViolated":null},"traceId":null,"_name":"Book Name Length","_description":"","value":null}],"_abstractionId":null,"_invariantViolated":false,"_name":"Book","_description":"This is the book accepted from the user. It has a name and a genre."}],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AcceptBookFromUser","_description":"This behavior accepts the book from the user."},"_goToBehaviorIds":["AddBookToBasket"],"_isAtomic":false,"_isDesignFork":false},{"dal_engine_uid":"f0e7bbeb-2824-4924-a66a-007d997a25fe","type":5,"_behavior":{"dal_engine_uid":"ae6907f3-bc1c-4e63-990d-1f98dece9d73","_type":1,"_participants":[],"_abstractionIds":[],"_invalidWorldState":false,"_name":"AddBookToBasket","_description":"This behavior places the accepted book in the basket."},"_goToBehaviorIds":[],"_isAtomic":false,"_isDesignFork":false}],"name":"AcceptBook","description":""}},"implementation":{"_sourceFiles":[{"name":"library_manager.py","path":"library_manager.py","content":"import sys\r\nimport uuid\r\nimport json\r\n\r\ndef place_books_on_shelf_from_basket(book_shelf, basket):\r\n    '''\r\n    This function checks to see if there are books in the\r\n    basket and places it on the shelf. It continues until\r\n    there are no more books left.\r\n    \r\n    :param book_shelf: Object representing the bookshelf.\r\n    :param basket: Array representing the basket.\r\n    '''\r\n    while len(basket[\"value\"]) > 0:\r\n        book = basket[\"value\"].pop()\r\n        print(f\"Accepted book: {book['value']['name']} (Genre: {book['value']['genre']})\")\r\n        \r\n        firstLetter = book[\"value\"]['name'][0]\r\n\r\n        if (firstLetter not in book_shelf[\"value\"]):\r\n            book_shelf[\"value\"][firstLetter] = []\r\n\r\n        book_shelf[\"value\"][firstLetter].append(book)\r\n\r\n    return book_shelf\r\n\r\ndef accept_book():\r\n    '''\r\n    This function accepts the book from the user.\r\n    '''\r\n    print(\"\\nEnter book details:\")        \r\n    name = input(\"Book name: \")\r\n    genre = input(\"Genre: \")\r\n    book_details = {\"uid\": str(uuid.uuid4()), \"value\": {\"name\": name, \"genre\":genre}}\r\n    return book_details\r\n\r\ndef library_manager():\r\n    '''\r\n    This function serves the library manager. \r\n\r\n    It provides a menu that lets users add books to a basket and \r\n    place the books from the basket onto the shelf. It also allows\r\n    the user to display the contents of the library and finally, it\r\n    allows the user to exit the library.\r\n    '''\r\n\r\n    book_shelf = {\"uid\": str(uuid.uuid4()), \"value\":{}}\r\n\r\n    basket = {\"uid\": str(uuid.uuid4()), \"value\":[]}\r\n\r\n    while True:\r\n        \r\n        response = input(\r\n            \"\\n==========================\\n\"\\\r\n            \"         Menu:\\n\" \\\r\n            \"==========================\\n\"\\\r\n            \"Enter a: Add book.\\n\" \\\r\n            \"Enter p: Place books on shelf and continue.\\n\" \\\r\n            \"Enter d: Display contents of basket and book shelf.\\n\" \\\r\n            \"Enter any other key: Exit\\n\" \\\r\n            \"\\nResponse:\"\r\n        ).lower()\r\n\r\n        if response == \"a\":\r\n            book_details = accept_book()\r\n            basket[\"value\"].append(book_details)\r\n\r\n        elif response == \"p\":\r\n            if (len(basket) > 5):\r\n                raise Exception(\"Basket is too heavy, I can't bring it to the shelf.\")\r\n            book_shelf = place_books_on_shelf_from_basket(book_shelf, basket)\r\n\r\n        elif response == \"d\":\r\n            audit = {\"uid\": str(uuid.uuid4()), \"value\":{\"Book Shelf\": book_shelf, \"Basket\": basket}}\r\n            print(\"\\nLibrary Audit:\", json.dumps(audit[\"value\"], indent=2))\r\n\r\n        else:        \r\n            break\r\n\r\nif __name__ == \"__main__\":\r\n    sys.exit(library_manager())\r\n     ","updatedContent":"import sys\r\nimport uuid\r\nimport json\r\n\r\ndef place_books_on_shelf_from_basket(book_shelf, basket):\r\n    '''\r\n    This function checks to see if there are books in the\r\n    basket and places it on the shelf. It continues until\r\n    there are no more books left.\r\n    \r\n    :param book_shelf: Object representing the bookshelf.\r\n    :param basket: Array representing the basket.\r\n    '''\r\n    while len(basket[\"value\"]) > 0:\r\n        book = basket[\"value\"].pop()\r\n        print(f\"Accepted book: {book['value']['name']} (Genre: {book['value']['genre']})\")\r\n        \r\n        firstLetter = book[\"value\"]['name'][0]\r\n\r\n        if (firstLetter not in book_shelf[\"value\"]):\r\n            book_shelf[\"value\"][firstLetter] = []\r\n\r\n        book_shelf[\"value\"][firstLetter].append(book)\r\n\r\n    return book_shelf\r\n\r\ndef accept_book():\r\n    '''\r\n    This function accepts the book from the user.\r\n    '''\r\n    print(\"\\nEnter book details:\")        \r\n    name = input(\"Book name: \")\r\n    genre = input(\"Genre: \")\r\n    book_details = {\"uid\": str(uuid.uuid4()), \"value\": {\"name\": name, \"genre\":genre}}\r\n    return book_details\r\n\r\ndef library_manager():\r\n    '''\r\n    This function serves the library manager. \r\n\r\n    It provides a menu that lets users add books to a basket and \r\n    place the books from the basket onto the shelf. It also allows\r\n    the user to display the contents of the library and finally, it\r\n    allows the user to exit the library.\r\n    '''\r\n\r\n    book_shelf = {\"uid\": str(uuid.uuid4()), \"value\":{}}\r\n\r\n    basket = {\"uid\": str(uuid.uuid4()), \"value\":[]}\r\n\r\n    while True:\r\n        \r\n        response = input(\r\n            \"\\n==========================\\n\"\\\r\n            \"         Menu:\\n\" \\\r\n            \"==========================\\n\"\\\r\n            \"Enter a: Add book.\\n\" \\\r\n            \"Enter p: Place books on shelf and continue.\\n\" \\\r\n            \"Enter d: Display contents of basket and book shelf.\\n\" \\\r\n            \"Enter any other key: Exit\\n\" \\\r\n            \"\\nResponse:\"\r\n        ).lower()\r\n\r\n        if response == \"a\":\r\n            book_details = accept_book()\r\n            basket[\"value\"].append(book_details)\r\n\r\n        elif response == \"p\":\r\n            if (len(basket) > 5):\r\n                raise Exception(\"Basket is too heavy, I can't bring it to the shelf.\")\r\n            book_shelf = place_books_on_shelf_from_basket(book_shelf, basket)\r\n\r\n        elif response == \"d\":\r\n            audit = {\"uid\": str(uuid.uuid4()), \"value\":{\"Book Shelf\": book_shelf, \"Basket\": basket}}\r\n            print(\"\\nLibrary Audit:\", json.dumps(audit[\"value\"], indent=2))\r\n\r\n        else:        \r\n            break\r\n\r\nif __name__ == \"__main__\":\r\n    sys.exit(library_manager())\r\n     ","type":"file","uid":"9f7368cb-7972-4516-8f60-3f7b75f575c3","level":0,"collapsed":false,"isDirty":false},{"name":"README.md","path":"README.md","content":"- The files in the workspace are loaded from the implementation contained in the engine. \r\n\r\n- The implementation realizes the design contained in the engines graphs. \r\n\r\n- Anytime that the implementation is saved, the program will be parsed to extract the mappable statements, allowing the design to be mapped onto the implementation in the workbench.\r\n\r\n- The mapping will be instrumented onto the implementation, executed and the resulting trace will be transformed back into the behavior of the design, allowing it to be automatically debugged.","updatedContent":"- The files in the workspace are loaded from the implementation contained in the engine. \r\n\r\n- The implementation realizes the design contained in the engines graphs. \r\n\r\n- Anytime that the implementation is saved, the program will be parsed to extract the mappable statements, allowing the design to be mapped onto the implementation in the workbench.\r\n\r\n- The mapping will be instrumented onto the implementation, executed and the resulting trace will be transformed back into the behavior of the design, allowing it to be automatically debugged.","type":"file","uid":"2c5385dd-7c17-4216-b564-47c941e9a623","level":0,"collapsed":false,"isDirty":true}]}}